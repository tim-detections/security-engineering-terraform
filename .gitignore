# ==========================================
# Terraform - Never Commit Local State/Cache
# ==========================================

**/.terraform/
**/.terraform.lock.hcl

*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variable files (may contain secrets)
*.tfvars
!*.tfvars.example

# Crash logs
crash.log
crash.*.log

# Sensitive files
*.pem
*.key

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Windows artifacts
Thumbs.db
Desktop.ini

# VSCode
.vscode/

# OS generated files
.DS_Store
